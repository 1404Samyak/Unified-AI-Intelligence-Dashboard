NODE_ENV=development
AUTH_SECRET=change-this-local-dev-secret

# Hosted LLM API for deployment.
# Put the real value only in Render environment variables, not in GitHub.
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-20b

# One Postgres instance/database. Domain separation is done with schemas:
# library, cafeteria, events, academics.
DATABASE_URL=postgres://campus:campus@localhost:5432/campus_dashboard

# MCP server ports
LIBRARY_MCP_URL=http://localhost:4101/mcp
CAFETERIA_MCP_URL=http://localhost:4102/mcp
EVENTS_MCP_URL=http://localhost:4103/mcp
ACADEMICS_MCP_URL=http://localhost:4104/mcp

# API/frontend ports
API_PORT=4000
VITE_API_URL=http://localhost:4000
